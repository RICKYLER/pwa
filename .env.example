# App URL
NEXT_PUBLIC_APP_URL=https://your-app-domain.vercel.app

# Session signing
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="MSWDO Census" <your-email@example.com>

# Google Maps / Address Validation
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-browser-key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_ADDRESS_VALIDATION_API_KEY=your-google-address-validation-key

# Weather
OPENWEATHER_API_KEY=your-openweather-key

# Firebase App Check for Google Maps protection
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-ga-measurement-id
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key

# Optional app defaults
NEXT_PUBLIC_DEFAULT_BARANGAY_ID=barangay-1
NEXT_PUBLIC_DEFAULT_MUNICIPALITY=

# Optional map providers
NEXT_PUBLIC_THUNDERFOREST_API_KEY=
NEXT_PUBLIC_TRACESTRACK_KEY=

# Optional local file-based auth store path
# On Vercel, the code now falls back to writable /tmp scratch storage when these are unset.
# That avoids the /var/task/data error, but it is still temporary storage, not durable database storage.
MSWDO_AUTH_STORE_PATH=./data/auth-store.json
MSWDO_SYNC_BACKUP_STORE_PATH=./data/field-sync-backup.json
MSWDO_DATA_DIR=./data

# Supabase placeholders
# These are for the next step when the app code is wired to Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=


NEXT_PUBLIC_SUPABASE_URL=https://vtyqiwgesstjalkleiwa.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_wMaTtv4Dof1QkLHQ3PoHYA_icQWlALe

# Server only
DATABASE_URL=postgresql://postgres:YOUR-REAL-PASSWORD@db.vtyqiwgesstjalkleiwa.supabase.co:5432/postgres
